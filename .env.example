# Required.
MOMONGA_SEARCH_API_KEY=ms_live_xxx

# Optional API endpoint.
MOMONGA_BASE_URL=https://api.momongasearch.com/v1

# Optional local runtime settings.
MOMONGA_MCP_CACHE_DIR=~/.cache/momonga-search-mcp
MOMONGA_MCP_CACHE_ENABLED=true
MOMONGA_MCP_LOG_LEVEL=INFO

# Optional MCP-side guard limits.
MOMONGA_MCP_MAX_SECTIONS_PER_CONTENT_CALL=3
MOMONGA_MCP_MAX_CHARACTERS_PER_CONTENT_CALL=30000
MOMONGA_MCP_MAX_PAGE_IMAGES_PER_CALL=3
MOMONGA_MCP_MAX_ORIGINAL_FILES_PER_CALL=1
