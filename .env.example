# Required.
MOMONGA_SEARCH_API_KEY=ms_live_xxx

# Optional API endpoint.
MOMONGA_BASE_URL=https://api.momongasearch.com/v1

# Optional local runtime settings.
# Optional. Override the cache directory. If unset, the server uses the OS
# standard user cache directory for momonga-search-mcp.
# MOMONGA_SEARCH_MCP_CACHE_DIR=
# Optional. Maximum cache size in GB. The server prunes older cached resources
# after writes when this cap is exceeded.
# MOMONGA_SEARCH_MCP_CACHE_MAX_GB=1
MOMONGA_MCP_LOG_LEVEL=INFO
